generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String             @id @default(uuid())
  name                  String
  subscriptionPlan      String             @default("STARTER")
  subscriptionExpiresAt DateTime?
  isActive              Boolean            @default(true)
  maxQRCodes            Int                @default(100)
  maxUsers              Int                @default(5)
  maxProjects           Int                @default(1)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  activityLogs          ActivityLog[]
  conversations         Conversation[]
  files                 File[]
  incidents             Incident[]
  locationLogs          LocationLog[]
  notifications         Notification[]
  projects              Project[]
  qrcodes               QRCode[]
  rateLimitLogs         RateLimitLog[]
  rateLimitRules        RateLimitRule[]
  roles                 Role[]
  scanLogs              ScanLog[]
  subscriptions         Subscription[]
  tasks                 Task[]
  taskAttachments       TaskAttachment[]
  taskComments          TaskComment[]
  taskTemplates         TaskTemplate[]
  taskTimeEntries       TaskTimeEntry[]
  users                 User[]
  workflows             Workflow[]
  workflowApprovals     WorkflowApproval[]
  workflowInstances     WorkflowInstance[]

  @@index([subscriptionPlan])
  @@index([isActive])
}

model User {
  id                        String               @id @default(uuid())
  email                     String               @unique
  password                  String
  fullName                  String
  isTenantAdmin             Boolean              @default(false)
  isSuperAdmin              Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  tenantId                  String
  roleId                    String?
  status                    String               @default("active")
  avatar                    String?
  activityLogs              ActivityLog[]
  adminOfGroups             Conversation[]       @relation("GroupAdmin")
  conversations             ConversationMember[]
  files                     File[]
  reportedIncidents         Incident[]           @relation("IncidentReporter")
  locationLogs              LocationLog[]
  sentMessages              Message[]
  deletedMessages           MessageDeletedFor[]
  reactedMessages           MessageReaction[]
  seenMessages              MessageSeen[]
  notifications             Notification[]
  projectMembers            ProjectMember[]      @relation("UserToProjectMembers")
  rateLimitLogs             RateLimitLog[]
  createdRateLimitRules     RateLimitRule[]
  scanLogs                  ScanLog[]
  assignedTasks             Task[]               @relation("Assignee")
  createdTasks              Task[]               @relation("Creator")
  taskAttachments           TaskAttachment[]
  taskComments              TaskComment[]
  createdTaskTemplates      TaskTemplate[]
  taskTimeEntries           TaskTimeEntry[]
  role                      Role?                @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant                    Tenant               @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  createdWorkflows          Workflow[]
  approvedWorkflowApprovals WorkflowApproval[]   @relation("ApprovedBy")
  assignedWorkflowApprovals WorkflowApproval[]   @relation("AssignedTo")
  startedWorkflowInstances  WorkflowInstance[]

  @@index([tenantId])
  @@index([roleId])
  @@index([email])
}

model Role {
  id          String   @id @default(uuid())
  name        String
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  projectId   String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  users       User[]

  @@index([tenantId])
  @@index([name])
}

model Project {
  id            String          @id @default(uuid())
  name          String
  description   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  tenantId      String
  address       String?
  image         String?
  status        String          @default("active")
  conversations Conversation[]
  incidents     Incident[]
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  members       ProjectMember[] @relation("ProjectToProjectMembers")
  qrcodes       QRCode[]
  tasks         Task[]

  @@index([tenantId])
  @@index([name])
}

model ProjectMember {
  userId     String
  projectId  String
  assignedAt DateTime @default(now())
  project    Project  @relation("ProjectToProjectMembers", fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User     @relation("UserToProjectMembers", fields: [userId], references: [id], onUpdate: NoAction)

  @@id([userId, projectId])
}

model QRCode {
  id        String     @id @default(uuid())
  name      String
  location  String?
  data      String     @unique @default(cuid())
  isActive  Boolean    @default(true)
  latitude  Float?
  longitude Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  projectId String
  tenantId  String
  incidents Incident[]
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  scanLogs  ScanLog[]

  @@index([projectId])
  @@index([tenantId])
}

model Task {
  id             String           @id @default(uuid())
  title          String
  description    String?
  status         String           @default("PENDING")
  priority       String           @default("MEDIUM")
  tags           String?
  estimatedHours Float?
  actualHours    Float?
  notes          String?
  deadline       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  projectId      String
  creatorId      String
  assigneeId     String?
  tenantId       String
  incidents      Incident[]
  assignee       User?            @relation("Assignee", fields: [assigneeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator        User             @relation("Creator", fields: [creatorId], references: [id], onUpdate: NoAction)
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  attachments    TaskAttachment[]
  comments       TaskComment[]
  timeEntries    TaskTimeEntry[]

  @@index([projectId])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([tenantId])
}

model ScanLog {
  id          String     @id @default(cuid())
  scannedAt   DateTime   @default(now())
  notes       String?
  attachments String?
  qrCodeId    String
  userId      String
  tenantId    String
  location    String?
  latitude    Float?     @default(0)
  longitude   Float?     @default(0)
  accuracy    Float?     @default(0)
  status      String?    @default("VALID")
  incidents   Incident[]
  qrCode      QRCode     @relation(fields: [qrCodeId], references: [id], onUpdate: NoAction)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user        User       @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([qrCodeId])
  @@index([userId])
}

model Incident {
  id          String          @id @default(uuid())
  description String
  status      String          @default("OPEN")
  department  String?
  reportedAt  DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenantId    String
  projectId   String
  qrCodeId    String?
  scanLogId   String?
  taskId      String?
  reporterId  String?
  project     Project         @relation(fields: [projectId], references: [id], onUpdate: NoAction)
  qrCode      QRCode?         @relation(fields: [qrCodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reporter    User?           @relation("IncidentReporter", fields: [reporterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scanLog     ScanLog?        @relation(fields: [scanLogId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  images      IncidentImage[]

  @@index([tenantId])
  @@index([projectId])
}

model IncidentImage {
  id         String   @id @default(uuid())
  url        String
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Subscription {
  id              String    @id @default(uuid())
  plan            String
  price           Decimal   @db.Decimal(10, 2)
  status          String    @default("ACTIVE")
  startDate       DateTime  @default(now())
  endDate         DateTime
  autoRenew       Boolean   @default(true)
  paymentMethod   String?
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
  @@index([status])
}

model MasterAdmin {
  id           String              @id @default(uuid())
  email        String              @unique
  password     String
  fullName     String
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  activityLogs MasterActivityLog[]
}

model MasterActivityLog {
  id            String      @id @default(cuid())
  action        String
  details       String?
  entity        String?
  entityId      String?
  createdAt     DateTime    @default(now())
  masterAdminId String
  masterAdmin   MasterAdmin @relation(fields: [masterAdminId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([masterAdminId])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  tenantId  String
  userId    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([userId])
}

model LocationLog {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  address   String?
  createdAt DateTime @default(now())
  tenantId  String
  userId    String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([tenantId])
  @@index([userId])
}

model File {
  id           String   @id @default(uuid())
  fileName     String
  originalName String
  filePath     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  tenantId     String
  userId       String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user         User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([tenantId])
  @@index([userId])
}

model Workflow {
  id          String             @id @default(uuid())
  name        String
  description String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  tenantId    String
  createdById String
  createdBy   User               @relation(fields: [createdById], references: [id], onUpdate: NoAction)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  instances   WorkflowInstance[]
  steps       WorkflowStep[]

  @@index([tenantId])
  @@index([createdById])
}

model WorkflowStep {
  id         String   @id @default(uuid())
  name       String
  order      Int
  type       String
  config     String?
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workflowId])
}

model WorkflowInstance {
  id          String             @id @default(uuid())
  status      String             @default("PENDING")
  data        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workflowId  String
  startedById String
  tenantId    String
  approvals   WorkflowApproval[]
  startedBy   User               @relation(fields: [startedById], references: [id], onUpdate: NoAction)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  workflow    Workflow           @relation(fields: [workflowId], references: [id], onUpdate: NoAction)

  @@index([workflowId])
  @@index([startedById])
  @@index([tenantId])
}

model WorkflowApproval {
  id                 String           @id @default(uuid())
  status             String           @default("PENDING")
  comments           String?
  approvedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  workflowInstanceId String
  assignedToId       String
  approvedById       String?
  tenantId           String
  approvedBy         User?            @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTo         User             @relation("AssignedTo", fields: [assignedToId], references: [id], onUpdate: NoAction)
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workflowInstanceId])
  @@index([assignedToId])
}

model RateLimitRule {
  id          String         @id @default(uuid())
  name        String
  pattern     String
  method      String?
  limit       Int
  window      Int
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenantId    String
  createdById String
  logs        RateLimitLog[]
  createdBy   User           @relation(fields: [createdById], references: [id], onUpdate: NoAction)
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onUpdate: NoAction)

  @@index([tenantId])
}

model RateLimitLog {
  id           String        @id @default(uuid())
  ipAddress    String
  userAgent    String?
  requestCount Int           @default(1)
  windowStart  DateTime
  createdAt    DateTime      @default(now())
  tenantId     String
  userId       String?
  ruleId       String
  rule         RateLimitRule @relation(fields: [ruleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user         User?         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId])
  @@index([userId])
}

model TaskComment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  taskId    String
  userId    String
  tenantId  String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([taskId])
  @@index([userId])
}

model TaskAttachment {
  id           String   @id @default(uuid())
  fileName     String
  originalName String
  filePath     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  taskId       String
  userId       String
  tenantId     String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user         User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([taskId])
  @@index([userId])
}

model TaskTimeEntry {
  id          String    @id @default(uuid())
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  taskId      String
  userId      String
  tenantId    String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user        User      @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([taskId])
  @@index([userId])
}

model TaskTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  template    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onUpdate: NoAction)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)

  @@index([tenantId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  entity    String?
  entityId  String?
  createdAt DateTime @default(now())
  userId    String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([userId])
  @@index([tenantId])
}

model Conversation {
  id            String               @id @default(uuid())
  type          String               @default("DIRECT")
  name          String?
  avatar        String?
  lastMessageId String?
  updatedAt     DateTime             @default(now()) @updatedAt
  createdAt     DateTime             @default(now())
  projectId     String?
  tenantId      String
  adminId       String?
  lastMessageAt DateTime             @default(now())
  groupAdmin    User?                @relation("GroupAdmin", fields: [adminId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project       Project?             @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  members       ConversationMember[]
  messages      Message[]

  @@index([projectId])
  @@index([tenantId])
  @@index([lastMessageAt])
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  isMuted        Boolean      @default(false)
  unreadCount    Int          @default(0)
  joinedAt       DateTime     @default(now())
  isArchived     Boolean      @default(false)
  isPinned       Boolean      @default(false)
  lastSeenAt     DateTime     @default(now())
  role           String       @default("MEMBER")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String              @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  type           String              @default("TEXT")
  metadata       String?
  createdAt      DateTime            @default(now())
  isDeleted      Boolean             @default(false)
  replyToId      String?
  updatedAt      DateTime            @default(now()) @updatedAt
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation(fields: [senderId], references: [id], onUpdate: NoAction)
  deletedFor     MessageDeletedFor[]
  reactions      MessageReaction[]
  seenBy         MessageSeen[]

  @@index([conversationId])
  @@index([createdAt])
}

model MessageSeen {
  messageId String
  userId    String
  seenAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@id([messageId, userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  type      String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([messageId, userId])
}

model MessageDeletedFor {
  messageId String
  userId    String
  deletedAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@id([messageId, userId])
}